# Square webhook verification
# Get the Signature Key from: Square Developer Dashboard → Your App → Webhooks → your endpoint
SQUARE_WEBHOOK_SIGNATURE_KEY=your_webhook_signature_key_here
# Full URL of this webhook endpoint (must match exactly what you set in Square dashboard)
SQUARE_WEBHOOK_URL=https://mage-payment-backend.onrender.com/webhook/square

# Email confirmation (use Gmail App Password, not your normal password)
# To generate: Google Account → Security → 2-Step Verification → App Passwords
EMAIL_USER=magecards7@gmail.com
EMAIL_PASSWORD=your_gmail_app_password_here
EMAIL_FROM=magecards7@gmail.com
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
