# Square API credentials
# Get these from https://developer.squareup.com/apps

# Your Square Access Token (keep secret!)
SQUARE_ACCESS_TOKEN=your_access_token_here

# Your Square Location ID
SQUARE_LOCATION_ID=your_location_id_here

# Environment: "sandbox" for testing, "production" for live payments
SQUARE_ENVIRONMENT=sandbox

# PayPal API credentials
# Get these from https://developer.paypal.com/dashboard/applications

# Your PayPal App Client ID
PAYPAL_CLIENT_ID=your_paypal_client_id_here

# Your PayPal App Client Secret (keep secret!)
PAYPAL_CLIENT_SECRET=your_paypal_client_secret_here

# PayPal environment: "sandbox" for testing, "production" for live payments
PAYPAL_ENVIRONMENT=sandbox
