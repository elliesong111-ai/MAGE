# PayPal API credentials
# Get these from https://developer.paypal.com/dashboard/applications
PAYPAL_CLIENT_ID=your_paypal_client_id_here
PAYPAL_CLIENT_SECRET=your_paypal_client_secret_here

# Environment: "sandbox" for testing, "production" for live payments
PAYPAL_ENVIRONMENT=sandbox

# Email confirmation (use Gmail App Password, not your normal password)
# To generate: Google Account → Security → 2-Step Verification → App Passwords
EMAIL_USER=magecards7@gmail.com
EMAIL_PASSWORD=your_gmail_app_password_here
EMAIL_FROM=magecards7@gmail.com
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
